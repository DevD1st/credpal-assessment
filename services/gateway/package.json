{
  "name": "@credpal-fx-trading-app/gateway",
  "version": "1.0.0",
  "description": "Gateway service for Credpal FX App",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build:ts": "tsc -p ./tsconfig.json",
    "build": "nest build --builder tsc",
    "clean": "rm -rf ./dist ./tsconfig.tsbuildinfo",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "cross-env NODE_OPTIONS=\"--import=../../scripts/instrumentation.mjs\" nest start gateway",
    "dev": "cross-env NODE_OPTIONS=\"--import=../../scripts/instrumentation.mjs\" nest start gateway --watch --builder tsc",
    "debug": "nest start gateway --debug --watch",
    "prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@credpal-fx-trading-app/common": "^1.0.0",
    "@credpal-fx-trading-app/constants": "^1.0.0",
    "@credpal-fx-trading-app/proto": "^1.0.0",
    "@credpal-fx-trading-app/runtime": "^1.0.0",
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "@grpc/reflection": "^1.0.4",
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.20",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.20",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "reflect-metadata": "^0.2.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
