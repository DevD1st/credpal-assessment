{
  "name": "@credpal-fx-trading-app/gateway",
  "version": "1.0.0",
  "description": "Gateway service for Credpal FX App",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build:ts": "tsc -p ./tsconfig.json",
    "build": "nest build --builder tsc",
    "clean": "rm -rf ./dist ./tsconfig.tsbuildinfo",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start gateway",
    "dev": "nest start gateway --watch --builder tsc",
    "debug": "nest start gateway --debug --watch",
    "prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "@grpc/reflection": "^1.0.4",
    "@nestjs/common": "^11.0.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.20",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.20",
    "@credpal-fx-trading-app/common": "^1.0.0",
    "@credpal-fx-trading-app/constants": "^1.0.0",
    "@credpal-fx-trading-app/proto": "^1.0.0",
    "@credpal-fx-trading-app/runtime": "^1.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
